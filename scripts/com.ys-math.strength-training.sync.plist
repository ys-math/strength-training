<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Watches the StrongExports iCloud Drive folder and runs scripts/sync-data.sh
  when a new file appears, plus once daily as a fallback. See README.md
  ("Automatic sync via iCloud Drive") for install/uninstall steps.

  Install:   cp this file to ~/Library/LaunchAgents/, then
             launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.ys-math.strength-training.sync.plist
  Uninstall: launchctl bootout gui/$(id -u) ~/Library/LaunchAgents/com.ys-math.strength-training.sync.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ys-math.strength-training.sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/yutosasaki/github/strength-training/scripts/sync-data.sh</string>
  </array>

  <key>WatchPaths</key>
  <array>
    <string>/Users/yutosasaki/Library/Mobile Documents/com~apple~CloudDocs/StrongExports</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>ThrottleInterval</key>
  <integer>30</integer>

  <key>StandardOutPath</key>
  <string>/Users/yutosasaki/Library/Logs/strength-training-sync.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/yutosasaki/Library/Logs/strength-training-sync.log</string>
</dict>
</plist>
